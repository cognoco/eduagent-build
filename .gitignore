dist
tmp
out-tsc
*.tsbuildinfo

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Nx graph output
nx-graph.html
static/

# Next.js
.next
out

test-output

# TestSprite MCP generated tests (ephemeral, not committed)
testsprite_tests/

# Sentry auth token (local builds — never commit)
# Note: android/ is gitignored (Expo managed), so sentry.properties
# won't reach EAS builds. Use SENTRY_AUTH_TOKEN, SENTRY_ORG,
# SENTRY_PROJECT env vars in EAS Secrets instead.

# Environment variables
# IMPORTANT: .env.example IS tracked (template for developers)
# All other .env files contain secrets and MUST NOT be committed
.env*
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local
.env_old
.env.development.local_old

# Keep .env.example tracked
!.env.example

# Cloudflare Workers local secrets and state
.dev.vars
.wrangler/

nul
temp/*

# Git worktrees
.worktrees/
.claude/worktrees/

# Local Claude Code settings (personal tool permissions, output style)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local Claude Code session data and tool extensions (per-machine)
.claude/data/
.claude/zdx-tts/
apps/mobile/.claude/

# Hook log output (Claude Code session_start / user_prompt_submit / session_end)
/logs/
apps/mobile/logs/

# Playwright MCP session artifacts (console logs, page snapshots)
.playwright-mcp/

# E2E full-suite run logs
apps/mobile/e2e/scripts/full-suite-*.log
apps/mobile/e2e/scripts/full-suite-*.err.log

# TestSprite AI Testing (generated tests, ephemeral results)
testsprite_tests/

.env.tokens

# Expo native build output (generated by expo prebuild)
apps/mobile/android/
apps/mobile/ios/
/android/
/ios/

# Root-level app.json from expo prebuild (real config is apps/mobile/app.json)
/app.json

# Maestro E2E screenshots (generated by takeScreenshot commands)
apps/mobile/**/*.png
!apps/mobile/assets/**/*.png

# Personal dev notes
docs/test_start.md

# Expo
node_modules/
.expo/
.yarn/
dist/
npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
cache/

# Maestro E2E screenshots (land at repo root when run from project root)
/*.png

# E2E env backup (created by serve-exported-web.mjs, may survive a crash)
.env.local.e2e-bak

# Playwright web E2E artifacts
apps/mobile/e2e-web/.auth/
apps/mobile/e2e-web/playwright-report/
apps/mobile/e2e-web/test-results/
apps/mobile/e2e-web/test-results-*/

# JVM crash logs (Android emulator, Gradle)
hs_err_pid*.log

# ADB uiautomator dump artifacts
*uidump*.xml
*ui_dump*.xml
apps/mobile/window_dump*.xml

# Dev server / proxy / emulator log files (written by running processes)
bundle-proxy.current.log
bundle-proxy.current.err.log
emulator.log
emulator.err.log
metro.current.log
metro.current.err.log
tdz_check.js

# Maestro debug flows (local-only, not part of test suite)
apps/mobile/e2e/flows/_debug/

# E2E test run result artifacts (timestamped, local-only)
apps/mobile/e2e/scripts/*-results-*.txt
apps/mobile/e2e/scripts/regression-batch*.txt

# Codex tool logs (local-only)
.codex/

# Superpowers brainstorm tool scratch artifacts (HTML drafts, server PIDs,
# state files — local-only, never source of truth)
.superpowers/

# Notion bug-fix scratch artifacts (Notion API dumps, ad-hoc python/js
# scripts, raw response bodies, the script's results.json output). Some
# entries here have historically held a Notion API key — keep gitignored.
.tmp/
.tmp_notion/
/results.json
/.bug-bodies/
/.bug-pages.txt
/.bug-selection.json
/.bugfix-tmp/
/.notion-bug-bodies/
/.notion-bugs.json
/.notion-inprogress.json
/.notion-not-started.json
/.notion-query.json
/.notion-selected.json
/.notion-status-update.json
apps/api/.notion-*.json
.claude/notion_bugs.json
.scratch/
