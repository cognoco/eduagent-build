# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Nx graph output
nx-graph.html
static/

# Next.js
.next
out

test-output
.test-logs/

# TestSprite MCP generated tests (ephemeral, not committed)
testsprite_tests/

# Sentry auth token (local builds — never commit)
# Note: android/ is gitignored (Expo managed), so sentry.properties
# won't reach EAS builds. Use SENTRY_AUTH_TOKEN, SENTRY_ORG,
# SENTRY_PROJECT env vars in EAS Secrets instead.

# Environment variables
# IMPORTANT: .env.example IS tracked (template for developers)
# All other .env files contain secrets and MUST NOT be committed
.env*
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local
.env_old
.env.development.local_old

# Keep .env.example tracked
!.env.example

# Cloudflare Workers local secrets and state
.dev.vars
.wrangler/

# Generic credential files (primary control; the pre-commit secret scan backstops these)
*.pem
credentials.json

nul
temp/*

# Git worktrees
.worktrees/
.claude/worktrees/

# Local planning docs (Archon workflow plans, exploratory specs).
# These often embed environment-specific URLs, project IDs, and other
# infra hints that should not be tracked. Force-add (`git add -f`) if
# a doc is genuinely meant to be checked in.
# Leading slash anchors to repo root — must NOT match docs/plans/.
/plans/

# Archon runtime artifacts
.archon/state/
.archon/.env

# Local Claude Code settings (personal tool permissions, output style)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local Claude Code session data and tool extensions (per-machine)
.claude/data/
.claude/zdx-tts/
apps/mobile/.claude/

# Hook log output (Claude Code session_start / user_prompt_submit / session_end)
/logs/
apps/mobile/logs/

# Playwright MCP session artifacts (console logs, page snapshots)
.playwright-mcp/

# E2E full-suite run logs
apps/mobile/e2e/scripts/full-suite-*.log
apps/mobile/e2e/scripts/full-suite-*.err.log

# TestSprite AI Testing (generated tests, ephemeral results)
testsprite_tests/

.env.tokens

# Expo native build output (generated by expo prebuild)
apps/mobile/android/
apps/mobile/ios/
/android/
/ios/

# Root-level app.json from expo prebuild (real config is apps/mobile/app.json)
/app.json

# Maestro E2E screenshots (generated by takeScreenshot commands)
apps/mobile/**/*.png
!apps/mobile/assets/**/*.png

# Personal dev notes
docs/test_start.md

# Visual onboarding atlas — generated export artifacts (keep .gitkeep but not generated files)
docs/visual-artefacts/exports/png/*.png
docs/visual-artefacts/exports/pptx/*.pptx

# Expo
node_modules/
.expo/
.yarn/
dist/
npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
cache/

# Maestro E2E screenshots (land at repo root when run from project root)
/*.png

# E2E env backup (created by serve-exported-web.mjs, may survive a crash)
.env.local.e2e-bak

# Playwright web E2E artifacts
apps/mobile/e2e-web/.auth/
apps/mobile/e2e-web/playwright-report/
apps/mobile/e2e-web/test-results/
apps/mobile/e2e-web/test-results-*/

# JVM crash logs (Android emulator, Gradle)
hs_err_pid*.log

# ADB uiautomator dump artifacts
*uidump*.xml
*ui_dump*.xml
apps/mobile/window_dump*.xml

# Dev server / proxy / emulator log files (written by running processes)
bundle-proxy.current.log
bundle-proxy.current.err.log
emulator.log
emulator.err.log
metro.current.log
metro.current.err.log
tdz_check.js

# Maestro debug flows (local-only, not part of test suite)
apps/mobile/e2e/flows/_debug/

# E2E test run result artifacts (timestamped, local-only)
apps/mobile/e2e/scripts/*-results-*.txt
apps/mobile/e2e/scripts/regression-batch*.txt
apps/mobile/e2e/scripts/run-logs/*.log
apps/mobile/e2e/scripts/run-logs/**/*.log

# Codex tool logs (local-only)
.codex/

# Codex re-execution scratch (pre-edit .base snapshots + .patch diffs; regenerable)
.codex-tmp/

# Cosmo run artifacts (workitem.json + completion-summary.md per run; regenerable)
.cosmo-runs/

# Cosmo/Quartet local runtime artifacts (clacks ledgers, monitor logs, review outputs)
.cosmo-artifacts/
.cosmo-watch/
/--workstream
/_quartet/working/lanes/**/_state/*.jsonl
/_quartet/working/lanes/**/_state/monitor-manifest.json
/_quartet/working/lanes/**/_state/**/*.log
/_quartet/working/lanes/**/_state/**/state.json
/_quartet/working/lanes/**/_state/**/launched-transitions.json
/_quartet/working/lanes/**/_state/**/reviews/

# BMAD working artifacts (scratch specs, test designs — canonical docs live in docs/)
_bmad-output/

# Superpowers brainstorm tool scratch artifacts (HTML drafts, server PIDs,
# state files — local-only, never source of truth)
.superpowers/

# Challenge-Round simulated-learner corpus — bulky, per-run transcripts + metrics.
# Generated by `eval:llm:sim`; not a source of truth (see apps/api/eval-llm/README.md).
apps/api/eval-llm/corpus/

# Notion bug-fix scratch artifacts (Notion API dumps, ad-hoc python/js
# scripts, raw response bodies, the script's results.json output). Some
# entries here have historically held a Notion API key — keep gitignored.
.tmp/
.tmp_notion/
# Notion REST query / debug scratch files at repo root (e.g. .tmp-bug-934.json,
# .tmp-notion-envelope.json). The .tmp/ entry above only matches the directory.
.tmp-*
/results.json
/.bug-bodies/
/.bug-pages.txt
/.bug-selection.json
/.bugfix-tmp/
/.notion-bug-bodies/
/.notion-bugs.json
/.notion-inprogress.json
/.notion-not-started.json
/.notion-query.json
/.notion-selected.json
/.notion-status-update.json
apps/api/.notion-*.json
.claude/notion_bugs.json
/notion_bugs_tmp.json
/bug_ids.json
.scratch/
.claude/logs/
# Archon init-tracing run-specific telemetry — written per workflow run, never
# repo-wide config. Excluded so it doesn't get accidentally committed by future
# cleanup-PR workflow runs.
.claude/logfire-resource-attributes.json
.gstack/

# Native build credentials — provisioned via EAS / CI build secrets, never committed.
# google-services.json is checked in: Firebase API keys are restricted by SHA
# fingerprints + package name and Google recommends committing this file.
# GoogleService-Info.plist will be committed once Apple enrollment completes.
apps/mobile/GoogleService-Info.plist
apps/mobile/.eas-submit/
.stash-backup/

# Bug-fix coordinator scratchpad (branch-only)
.bugfix-p3/

# Identity-cutover orchestration channel scratch — working-tree-only, never tracked (WI-586 hygiene, ic-orch-065)
_wip/identity-cutover/_state/*.jsonl
