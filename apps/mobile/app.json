{
  "expo": {
    "name": "MentoMate",
    "slug": "mentomate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mentomate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.mentomate.app",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.mentomate.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a3e"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a3e"
        }
      ],
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MentoMate needs camera access to photograph your homework."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MentoMate needs photo library access to import homework from your gallery.",
          "microphonePermission": false
        }
      ],
      "expo-notifications",
      [
        "@sentry/react-native/expo",
        {
          "organization": "zwizzly",
          "project": "mentomate-mobile",
          "uploadSourceMaps": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "MentoMate needs microphone access for voice-based learning."
        }
      ],
      "expo-updates",
      "./plugins/withForceDarkDisabled",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cbb7c7e1-cf56-45f2-9df8-f043bb8bb361"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "privacyPolicyUrl": "https://mentomate.com/privacy-policy",
    "updates": {
      "url": "https://u.expo.dev/cbb7c7e1-cf56-45f2-9df8-f043bb8bb361",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    },
    "owner": "zuzanka14"
  }
}
