# Synced to eas.json build profiles by: pnpm env:sync
# For local dev, generated from Doppler into apps/mobile/.env.local
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
EXPO_PUBLIC_ENABLE_MODE_NAV=false
# HMAC-SHA256 key for pseudonymising profile IDs in Sentry analytics tags.
# Required in production builds (apps/mobile/src/lib/analytics.ts throws when
# missing and __DEV__=false). Optional in local dev — a named fallback is used.
# Doppler path: mentomate → (env) → EXPO_PUBLIC_ANALYTICS_HASH_KEY_V1
EXPO_PUBLIC_ANALYTICS_HASH_KEY_V1=
