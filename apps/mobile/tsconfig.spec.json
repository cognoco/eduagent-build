{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "noUnusedLocals": true
  },
  "files": ["src/test-setup.ts"],
  "include": [
    "jest.config.cjs",
    "e2e-web/helpers/e2e-defaults.d.ts",
    "e2e-web/helpers/mentor-audit-storage-state.ts",
    "e2e-web/helpers/runtime.ts",
    "test-utils/**/*.ts",
    "test-utils/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "scripts/**/*.ts",
    "scripts/**/*.tsx"
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
