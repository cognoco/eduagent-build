import {
  isLocalHour9ForTimezone,
  listEligibleSelfReportProfileIds,
  listEligibleSelfReportProfileIdsAtLocalHour9,
} from './self-progress-reports';

function createMockDb() {
  const activityWhere = jest.fn().mockResolvedValue([]);
  const timezoneWhere = jest.fn().mockResolvedValue([]);

  return {
    db: {
      selectDistinct: jest.fn(() => ({
        from: jest.fn(() => ({
          where: activityWhere,
        })),
      })),
      select: jest.fn(() => ({
        from: jest.fn(() => ({
          innerJoin: jest.fn(() => ({
            where: timezoneWhere,
          })),
        })),
      })),
      query: {
        profiles: {
          findMany: jest.fn().mockResolvedValue([]),
        },
        familyLinks: {
          findMany: jest.fn().mockResolvedValue([]),
        },
        consentStates: {
          findMany: jest.fn().mockResolvedValue([]),
        },
      },
    },
    activityWhere,
    timezoneWhere,
  };
}

describe('listEligibleSelfReportProfileIds', () => {
  it('returns owner profiles with activity, no child link, and no restrictive consent row', async () => {
    const { db, activityWhere } = createMockDb();
    activityWhere.mockResolvedValue([
      { profileId: '11111111-1111-4111-8111-111111111111' },
    ]);
    db.query.profiles.findMany.mockResolvedValue([
      {
        id: '11111111-1111-4111-8111-111111111111',
        accountId: 'aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa',
        birthYear: 1998,
      },
    ]);

    const result = await listEligibleSelfReportProfileIds(db as never, {
      start: new Date('2026-05-01T00:00:00.000Z'),
      endExclusive: new Date('2026-06-01T00:00:00.000Z'),
    });

    expect(result).toEqual(['11111111-1111-4111-8111-111111111111']);
  });

  it('filters out underage, linked, and non-consented profiles using latest GDPR status', async () => {
    const { db, activityWhere } = createMockDb();
    activityWhere.mockResolvedValue([
      { profileId: '11111111-1111-4111-8111-111111111111' },
      { profileId: '22222222-2222-4222-8222-222222222222' },
      { profileId: '33333333-3333-4333-8333-333333333333' },
      { profileId: '44444444-4444-4444-8444-444444444444' },
    ]);
    db.query.profiles.findMany.mockResolvedValue([
      {
        id: '11111111-1111-4111-8111-111111111111',
        accountId: 'aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa',
        birthYear: 2018,
      },
      {
        id: '22222222-2222-4222-8222-222222222222',
        accountId: 'bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb',
        birthYear: 1995,
      },
      {
        id: '33333333-3333-4333-8333-333333333333',
        accountId: 'cccccccc-cccc-4ccc-8ccc-cccccccccccc',
        birthYear: 1992,
      },
      {
        id: '44444444-4444-4444-8444-444444444444',
        accountId: 'dddddddd-dddd-4ddd-8ddd-dddddddddddd',
        birthYear: 1991,
      },
    ]);
    db.query.familyLinks.findMany.mockResolvedValue([
      { childProfileId: '22222222-2222-4222-8222-222222222222' },
    ]);
    db.query.consentStates.findMany.mockResolvedValue([
      {
        profileId: '33333333-3333-4333-8333-333333333333',
        status: 'WITHDRAWN',
        requestedAt: new Date('2026-05-02T10:00:00.000Z'),
      },
      {
        profileId: '44444444-4444-4444-8444-444444444444',
        status: 'PENDING',
        requestedAt: new Date('2026-05-01T10:00:00.000Z'),
      },
      {
        profileId: '44444444-4444-4444-8444-444444444444',
        status: 'CONSENTED',
        requestedAt: new Date('2026-04-01T10:00:00.000Z'),
      },
    ]);

    const result = await listEligibleSelfReportProfileIds(db as never, {
      start: new Date('2026-05-01T00:00:00.000Z'),
      endExclusive: new Date('2026-06-01T00:00:00.000Z'),
    });

    expect(result).toEqual([]);
  });
});

describe('listEligibleSelfReportProfileIdsAtLocalHour9', () => {
  it('keeps only profiles whose account timezone is at local 09:00', async () => {
    const { db, activityWhere, timezoneWhere } = createMockDb();
    activityWhere.mockResolvedValue([
      { profileId: '11111111-1111-4111-8111-111111111111' },
      { profileId: '22222222-2222-4222-8222-222222222222' },
    ]);
    db.query.profiles.findMany.mockResolvedValue([
      {
        id: '11111111-1111-4111-8111-111111111111',
        accountId: 'aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa',
        birthYear: 1998,
      },
      {
        id: '22222222-2222-4222-8222-222222222222',
        accountId: 'bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb',
        birthYear: 1998,
      },
    ]);
    timezoneWhere.mockResolvedValue([
      {
        profileId: '11111111-1111-4111-8111-111111111111',
        timezone: 'UTC',
      },
      {
        profileId: '22222222-2222-4222-8222-222222222222',
        timezone: 'Europe/Oslo',
      },
    ]);

    const result = await listEligibleSelfReportProfileIdsAtLocalHour9(
      db as never,
      {
        start: new Date('2026-05-04T00:00:00.000Z'),
        endExclusive: new Date('2026-05-11T00:00:00.000Z'),
      },
      new Date('2026-05-11T09:00:00.000Z'),
    );

    expect(result).toEqual(['11111111-1111-4111-8111-111111111111']);
  });
});

describe('isLocalHour9ForTimezone', () => {
  it('falls back to UTC hour when timezone is missing or invalid', () => {
    const nineUtc = new Date('2026-05-11T09:00:00.000Z');
    expect(isLocalHour9ForTimezone(null, nineUtc)).toBe(true);
    expect(isLocalHour9ForTimezone('Not/AZone', nineUtc)).toBe(true);
  });
});
