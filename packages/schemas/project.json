{
  "name": "@eduagent/schemas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/schemas/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "packages/schemas",
        "command": "tsc --build tsconfig.lib.json"
      },
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/schemas",
        "commands": [
          "tsc --project tsconfig.lib.json --noEmit",
          "tsc --project tsconfig.spec.json --noEmit"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": []
    },
    "format:check": {}
  }
}
