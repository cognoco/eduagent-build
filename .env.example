# =============================================================================
# Environment Variables Template
# =============================================================================
# DO NOT put real credentials here - this file is tracked in git.
#
# SETUP:
#   1. Copy to .env.development.local (and .env.test.local if needed)
#   2. Fill in credentials from your service dashboards
#   3. Verify by running: pnpm exec tsc --noEmit
#
# REQUIRED FILES (each with different credentials):
# - .env.development.local  (local development)
# - .env.test.local          (CI/CD testing)
# - .env.production.local    (production — when needed)
#
# SECURITY:
# - All .env.*.local files are gitignored and should NEVER be committed
# =============================================================================

# =============================================================================
# DATABASE (Neon PostgreSQL)
# =============================================================================
# Get from: Neon Console → Project → Connection Details
# Pooled connection for application queries
DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require"
# Direct connection for migrations
DIRECT_URL="postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require"

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Get from: Resend Dashboard → API Keys (https://resend.com/api-keys)
# Used for transactional emails (consent requests, reminders)
RESEND_API_KEY="re_..."
# Sender address — must be a verified domain in Resend
EMAIL_FROM="noreply@mentomate.com"

# =============================================================================
# SENTRY ERROR TRACKING
# =============================================================================
# Get from: sentry.io → Project Settings → Client Keys (DSN)

# DSN for API (Cloudflare Workers) — add to Doppler project mentomate (wrangler secret put is banned per AGENTS.md)
# SENTRY_DSN="https://[KEY]@[ORG-ID].ingest.[REGION].sentry.io/[PROJECT-ID]"

# DSN for Expo mobile app
# EXPO_PUBLIC_SENTRY_DSN="https://[KEY]@[ORG-ID].ingest.[REGION].sentry.io/[PROJECT-ID]"

# Sentry org and project slugs (for source map uploads)
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="your-project-slug"
SENTRY_AUTH_TOKEN="sntrys_..."

# =============================================================================
# CLERK AUTHENTICATION (Mobile)
# =============================================================================
# Get from: Clerk Dashboard → API Keys → Publishable key
# EXPO_PUBLIC_ prefix is required for client-side access in Expo
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# JWKS URL for API-side JWT verification (used by auth middleware)
# Get from: Clerk Dashboard → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL="https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json"

# Clerk Backend API secret key. Used server-side for email-verification
# fallback lookups AND to delete the Clerk login identity when an account is
# deleted (GDPR Art 17 erasure — see apps/api/src/inngest/functions/account-deletion.ts).
# Optional in local dev, but REQUIRED in staging and production (config.ts
# STAGING_AND_PRODUCTION_REQUIRED_KEYS) — without it, account deletion cannot
# erase the external login and the Inngest job will retry and alert.
# Get from: Clerk Dashboard → API Keys → Secret key. Doppler: mentomate → CLERK_SECRET_KEY
CLERK_SECRET_KEY="sk_test_..."

# Optional: Clerk custom OIDC provider key for OpenAI SSO.
# When set, renders an "OpenAI" sign-in/sign-up button on the auth screens.
# When unset (default), the OpenAI SSO button is hidden; all other auth flows
# are unaffected — safe to leave blank in dev unless you are testing SSO.
#
# How to obtain: Clerk Dashboard → User & Authentication → Social Connections →
#   Add connection → Custom OIDC → follow the OpenAI OAuth app setup guide.
#   The value here is the short provider slug you assigned (e.g. "openai");
#   the app constructs the full strategy name as `oauth_custom_<key>`.
#
# Doppler path: mentomate → (env) → EXPO_PUBLIC_CLERK_OPENAI_SSO_SLUG
# EXPO_PUBLIC_ prefix means this value is baked into the JS bundle at build
# time — changing it requires a new native build (not an OTA update).
# EXPO_PUBLIC_CLERK_OPENAI_SSO_SLUG="openai"

# =============================================================================
# LLM PROVIDERS
# =============================================================================
# Get from: Google AI Studio → API Keys
GEMINI_API_KEY="your-gemini-api-key"

# =============================================================================
# EMBEDDING PROVIDER (Voyage AI)
# =============================================================================
# Get from: Voyage AI Dashboard → API Keys (https://dashboard.voyageai.com/)
# Model: voyage-3.5 (1024 dimensions, Anthropic's recommended partner)
# Free tier: 200M tokens
VOYAGE_API_KEY="pa-..."

# =============================================================================
# ANALYTICS
# =============================================================================
# HMAC-SHA256 key used by apps/mobile/src/lib/analytics.ts to pseudonymise
# profile IDs before they are emitted as Sentry tags. Required in production
# builds — the app throws (and emits a Sentry event) when this is missing and
# __DEV__ is false. In local dev a clearly-named fallback is used automatically
# so this key is optional during development.
# Doppler path: mentomate → (env) → EXPO_PUBLIC_ANALYTICS_HASH_KEY_V1
# EXPO_PUBLIC_ prefix means the value is baked into the JS bundle at build time.
EXPO_PUBLIC_ANALYTICS_HASH_KEY_V1="your-analytics-hash-key-v1"

# =============================================================================
# APPLICATION
# =============================================================================
# Base URL for the app (used in consent emails, etc.)
APP_URL="https://app.mentomate.com"

# Environment name (used by request-logger and config validation)
ENVIRONMENT="development"

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL="info"

# =============================================================================
# DATA RETENTION
# =============================================================================
# Master switch for the daily transcript-purge cron (transcript-purge-cron,
# 0 5 * * *). When "true", chat transcripts (session_events) older than the
# retention window are permanently deleted each day and re-embedded from their
# summaries; the derived learning memory is preserved. When "false" (the
# schema default), the cron is a no-op and raw transcripts are retained
# indefinitely.
#
# REQUIRED "true" IN PRODUCTION: the published privacy policy and the E5 DPIA
# both commit to a 30-day transcript-retention limit (GDPR storage limitation,
# Art 5(1)(e)). If this is unset/false in prod, that commitment is violated.
# Confirmed live ("true") in prod Doppler as of 2026-06-08. Do not regress.
# Doppler path: mentomate → (env) → RETENTION_PURGE_ENABLED
RETENTION_PURGE_ENABLED="false"

# =============================================================================
# STRIPE BILLING
# =============================================================================
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs from Stripe Dashboard → Products → Prices
STRIPE_PRICE_PLUS_MONTHLY="price_..."
STRIPE_PRICE_PLUS_YEARLY="price_..."
STRIPE_PRICE_FAMILY_MONTHLY="price_..."
STRIPE_PRICE_FAMILY_YEARLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."

# Optional: Stripe Customer Portal URL
# STRIPE_CUSTOMER_PORTAL_URL="https://billing.stripe.com/p/login/test_..."

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
# NODE_ENV="development"
