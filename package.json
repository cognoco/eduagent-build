{
  "name": "@eduagent/source",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": "22.x",
    "npm": "please-use-pnpm",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "C:/Tools/doppler/doppler.exe run -- nx run-many -t test",
    "test:api:unit": "jest --config apps/api/jest.config.cjs --runInBand",
    "test:api:integration": "C:/Tools/doppler/doppler.exe run -- jest --config apps/api/jest.config.cjs --no-coverage --runInBand",
    "test:mobile:unit": "jest --config apps/mobile/jest.config.cjs --runInBand --forceExit",
    "test:coverage": "nx run-many -t test --coverage",
    "lint": "nx run-many -t lint",
    "format:check": "nx run-many -t format:check",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,html}\"",
    "prepare": "husky",
    "db:push:dev": "C:/Tools/doppler/doppler.exe run -- pnpm --filter @eduagent/database exec tsx node_modules/drizzle-kit/bin.cjs push",
    "db:generate": "C:/Tools/doppler/doppler.exe run -- pnpm --filter @eduagent/database exec tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate:dev": "C:/Tools/doppler/doppler.exe run -- pnpm --filter @eduagent/database exec tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio:dev": "C:/Tools/doppler/doppler.exe run -- pnpm --filter @eduagent/database exec tsx node_modules/drizzle-kit/bin.cjs studio",
    "test:integration": "C:/Tools/doppler/doppler.exe run -- jest --config tests/integration/jest.config.cjs --no-coverage",
    "pretest:e2e": "node -e \"if (process.env.SKIP_E2E_GUARD) { process.exit(0); } console.error('\\n❌ pnpm test:e2e is broken: bare maestro resolves via PATH to a Unicode-broken install.\\nUse C:/Tools/maestro/bin/maestro.bat directly. See docs/E2Edocs/e2e-runbook.md\\nSet SKIP_E2E_GUARD=1 in CI to bypass this guard.\\n'); process.exit(1)\"",
    "test:e2e": "maestro test apps/mobile/e2e/flows/",
    "pretest:e2e:smoke": "node -e \"if (process.env.SKIP_E2E_GUARD) { process.exit(0); } console.error('\\n❌ pnpm test:e2e:smoke is broken: bare maestro resolves via PATH to a Unicode-broken install.\\nUse C:/Tools/maestro/bin/maestro.bat directly. See docs/E2Edocs/e2e-runbook.md\\nSet SKIP_E2E_GUARD=1 in CI to bypass this guard.\\n'); process.exit(1)\"",
    "test:e2e:smoke": "maestro test apps/mobile/e2e/flows/ --include-tags=smoke",
    "test:e2e:web": "pnpm exec playwright test -c apps/mobile/playwright.config.ts",
    "test:e2e:web:smoke": "pnpm exec playwright test -c apps/mobile/playwright.config.ts --project=smoke-auth --project=smoke-learner --project=smoke-parent",
    "pretest:e2e:record": "node -e \"if (process.env.SKIP_E2E_GUARD) { process.exit(0); } console.error('\\n❌ pnpm test:e2e:record is broken: bare maestro resolves via PATH to a Unicode-broken install.\\nUse C:/Tools/maestro/bin/maestro.bat directly. See docs/E2Edocs/e2e-runbook.md\\nSet SKIP_E2E_GUARD=1 in CI to bypass this guard.\\n'); process.exit(1)\"",
    "test:e2e:record": "maestro record apps/mobile/e2e/flows/",
    "env:sync": "node scripts/setup-env.js",
    "verify:postinstall-safety": "node scripts/verify-no-secret-postinstall.cjs",
    "check:root-deps": "node scripts/check-no-mobile-deps-at-root.cjs",
    "secrets:sync": "node scripts/sync-secrets.js",
    "eval:llm": "tsx apps/api/eval-llm/index.ts",
    "measure:t2fp": "tsx scripts/measure-time-to-first-prompt.ts",
    "translate": "doppler run -- pnpm exec tsx scripts/translate-gemini.ts",
    "check:i18n": "tsx scripts/check-i18n-staleness.ts",
    "check:i18n:orphans": "tsx scripts/check-i18n-orphan-keys.ts"
  },
  "private": true,
  "dependencies": {
    "dotenv": "^16.4.5",
    "react": "19.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/runtime": "~7.27.6",
    "@cloudflare/workers-types": "^4.0.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "^2.1.1",
    "@eslint/js": "^9.8.0",
    "@expo/cli": "~54.0.16",
    "@naxodev/nx-cloudflare": "^5.0.0",
    "@nx/devkit": "22.2.0",
    "@nx/esbuild": "22.2.0",
    "@nx/eslint": "22.2.0",
    "@nx/eslint-plugin": "22.2.0",
    "@nx/expo": "22.2.0",
    "@nx/jest": "22.2.0",
    "@nx/js": "22.2.0",
    "@nx/node": "22.2.0",
    "@nx/react": "22.2.0",
    "@nx/workspace": "22.2.0",
    "@playwright/test": "1.56.1",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "^1.13.5",
    "@swc/helpers": "~0.5.11",
    "@swc/jest": "~0.2.38",
    "@testing-library/react-native": "~13.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "19.1.0",
    "babel-jest": "30.2.0",
    "babel-preset-expo": "~54.0.7",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.19.2",
    "eslint": "9.37.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "hono": "^4.11.0",
    "husky": "^9.1.7",
    "jest": "30.2.0",
    "jest-environment-node": "30.2.0",
    "jest-expo": "~54.0.13",
    "jest-util": "30.2.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.2.5",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "nx": "22.2.0",
    "pg": "^8.20.0",
    "prettier": "^3.0.0",
    "react-dom": "19.1.0",
    "tailwindcss": "~3.4.19",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "wrangler": "^4.0.0"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-native-worklets": "0.7.4"
    },
    "patchedDependencies": {
      "react-native-css-interop@0.2.1": "patches/react-native-css-interop@0.2.1.patch"
    }
  }
}
