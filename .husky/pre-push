#!/usr/bin/env sh
# pre-push hook
#
# Change-class checklist (advisory).
# Non-blocking. Prints validation commands beyond what pre-commit enforces.

if [ -f scripts/check-change-class.sh ]; then
  echo ""
  echo "── Change Class Checklist (advisory) ──────────────────────────"
  bash scripts/check-change-class.sh --branch 2>/dev/null || true
  echo ""
fi
