#!/usr/bin/env sh
set -e

# Secret / large-file guard (WI-450 / gate-spec D3). Relocated out of the commit
# skill into the hook so it runs for EVERY committer (human, agent, /commit, raw
# git), not just when a skill chooses to scan. .gitignore is the primary control;
# this is the backstop for files force-added (`git add -f`) or slipping a
# gitignore gap. Path/extension-based and deterministic — no content scanning, so
# no false positives. Genuine false positive: unstage, or `git commit --no-verify`.
STAGED_ALL=$(git diff --cached --name-only --diff-filter=d)
if [ -n "$STAGED_ALL" ]; then
  SECRET_HITS=$(echo "$STAGED_ALL" \
    | grep -E '(^|/)(\.env(\.|$)|\.dev\.vars$|\.env\.tokens$|credentials\.json$)|\.(pem|key|p8|p12|jks|mobileprovision)$' \
    | grep -vE '(^|/)\.env\.example$' || true)
  if [ -n "$SECRET_HITS" ]; then
    echo ""
    echo "pre-commit: refusing to commit likely secret/credential file(s):"
    echo "$SECRET_HITS" | sed 's/^/  /'
    echo ""
    echo "These match secret patterns. Unstage them, or add to .gitignore."
    echo "Genuine false positive: git commit --no-verify."
    exit 1
  fi
  # Large-file guard — block staged blobs > 5 MB (accidental binaries / dumps).
  echo "$STAGED_ALL" | while IFS= read -r f; do
    [ -n "$f" ] || continue
    sz=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
    if [ "$sz" -gt 5242880 ]; then
      echo ""
      echo "pre-commit: staged file exceeds 5 MB ($((sz / 1048576)) MB): $f"
      echo "Large binaries belong in Git LFS or .gitignore. Bypass: --no-verify."
      exit 1
    fi
  done
fi

# lint-staged concurrency is OS-gated (WI-537). On Windows, parallel chunk
# execution (the default) spawns simultaneous `node --stack-size=65536`
# processes that exhaust process handles / memory → SIGKILL on large staged
# sets, so Windows forces serial. macOS/Linux use the parallel default (a few
# seconds faster). Windows (native + WSL) is an OS in active use — the serial
# path must stay for it (see MMT-ADR-0019). husky runs under Git-Bash on
# Windows, so uname -s is MINGW*/MSYS*/CYGWIN* there.
case "$(uname -s)" in
  MINGW* | MSYS* | CYGWIN*) LINT_STAGED_CONCURRENCY="--concurrent false" ;;
  *) LINT_STAGED_CONCURRENCY="" ;;
esac
# shellcheck disable=SC2086 # intentional word-splitting of the flag
pnpm exec lint-staged $LINT_STAGED_CONCURRENCY

# [Low / deps-supply-chain] Guard: fail fast when a mobile-only dep is added to
# the root package.json. The NativeWind double-copy bug means this check must
# fire at commit time, not only in CI. Instantaneous — runs before tsc.
if git diff --cached --name-only | grep -q 'package\.json'; then
  pnpm run check:root-deps || exit 1
fi

# [Low / deps-supply-chain] Guard: fail fast when a dependency's postinstall
# script can read secrets from the environment. Protects against supply-chain
# attacks via malicious postinstall hooks.
if git diff --cached --name-only | grep -q 'package\.json'; then
  pnpm run verify:postinstall-safety || exit 1
fi

# Cross-runtime sync: .claude/skills/ is generated from .agents/skills/. Use
# --print-changed so we stage exactly the files this sync run touched, not
# every working-tree edit under .claude/skills/. That distinction matters for
# files intentionally excluded from sync (e.g. the commit skill, see
# SKIP_SKILLS in scripts/sync-skills.mjs) where direct edits are valid and
# should not be auto-staged. Status messages go to stderr in this mode; stdout
# is one repo-relative path per line.
# (AGENTS.md <-> CLAUDE.md no longer need syncing: as of WI-386 AGENTS.md is the
# single source and CLAUDE.md is a thin `@AGENTS.md` pointer, so divergence is
# structurally impossible — there is nothing to sync between them.)
SYNC_CHANGES=$(node scripts/sync-skills.mjs --print-changed)
if [ -n "$SYNC_CHANGES" ]; then
  echo "pre-commit: auto-staging sync-generated changes:"
  echo "$SYNC_CHANGES" | sed 's/^/  /'
  echo "$SYNC_CHANGES" | xargs git add
fi

# Eval-harness guard: prompt-touching files require an accompanying snapshot
# diff. Without this, prompt drift ships silently (the eval harness only
# catches it post-hoc on the next manual run). See AGENTS.md "When changing
# LLM prompts, run the eval harness".
#
# Triggers on staged changes to:
#   - apps/api/src/services/**/*-prompts.ts
#   - apps/api/src/services/llm/**/*.ts (including providers/, excluding tests)
#   - apps/api/src/services/dictation/generate.ts (inline prompt construction)
# Parser/projector-only LLM infrastructure files are excluded because they do
# not contribute to prompt snapshot output; still run pnpm eval:llm manually
# for those changes per AGENTS.md.
# Excluded files (response-side only, cannot change what the model generates):
#   envelope, project-response, stream-envelope — response shaping/projection;
#   extract-json — a pure JSON-from-text parser that runs AFTER generation.
# Do NOT add prompt-building helpers here; this list is for files that process
# the model's output, never its input.
# Requires at least one staged file under apps/api/eval-llm/snapshots/.
# Bypass with `git commit --no-verify` if the change is a pure refactor.
PROMPT_CHANGED=$(git diff --cached --name-only --diff-filter=d \
  | grep -E '(apps/api/src/services/.*-prompts\.ts$|apps/api/src/services/llm/.+\.ts$|apps/api/src/services/dictation/generate\.ts$)' \
  | grep -vE '(\.test\.ts$|apps/api/src/services/llm/(envelope|project-response|stream-envelope|extract-json)\.ts$)' || true)
if [ -n "$PROMPT_CHANGED" ]; then
  SNAPSHOT_CHANGED=$(git diff --cached --name-only \
    | grep -E '^apps/api/eval-llm/snapshots/' || true)
  if [ -z "$SNAPSHOT_CHANGED" ]; then
    echo ""
    echo "pre-commit: prompt-touching files staged without a snapshot diff."
    echo ""
    echo "Files that triggered the check:"
    echo "$PROMPT_CHANGED" | sed 's/^/  /'
    echo ""
    echo "Run: pnpm eval:llm   (then re-stage the snapshot files)"
    echo ""
    echo "If this change cannot affect generation output (pure refactor,"
    echo "rename, comment, type-only), pass --no-verify."
    exit 1
  fi
fi

# i18n staleness guard: when en.json is staged, every locale must already match
# its key/variable shape. Without this the staleness check exists but never
# runs in CI/husky, so missing-key drift ships silently. Skip when only
# non-en locale files are staged (translator output committing back).
I18N_EN_CHANGED=$(git diff --cached --name-only --diff-filter=d \
  | grep -E '^apps/mobile/src/i18n/locales/en\.json$' || true)
if [ -n "$I18N_EN_CHANGED" ]; then
  echo "pre-commit: running check:i18n (en.json changed)..."
  pnpm exec tsx scripts/check-i18n-staleness.ts || exit 1
  # No-clinical-copy ratchet (Phase 5 of Challenge Round runtime). Banned
  # tone words (failed/wrong/struggle/weak/etc.) in learner-visible strings
  # must be reframed positively. Existing offenses are grandfathered in
  # scripts/no-clinical-copy-baseline.json — only NEW offenses fail. Run
  # with --accept to update the baseline when a new entry is genuinely
  # technical-error copy.
  echo "pre-commit: running check:no-clinical-copy (en.json changed)..."
  pnpm exec tsx scripts/check-no-clinical-copy.ts || exit 1
fi

# i18n orphan / unused-key check — independent of the en.json-gated staleness
# block above. The reverse-orphan case (a t() call site deleted but its en.json
# key left behind) is by definition a TSX-only change with NO en.json edit, so
# it must also fire on .ts/.tsx and keep-list edits. See
# docs/specs/2026-05-26-i18n-phase2-ui-strings-hygiene.md → Architecture/3.
if git diff --cached --name-only | grep -qE '^(apps/mobile/src/.*\.(ts|tsx)|apps/mobile/src/i18n/locales/en\.json|scripts/i18n-keep\.ts)$'; then
  echo "pre-commit: running check-i18n-orphan-keys + keep-rot..."
  pnpm exec tsx scripts/check-i18n-orphan-keys.ts || exit 1
  pnpm exec tsx scripts/check-i18n-keep-rot.ts || exit 1
fi

# GC1 ratchet (pre-commit mirror of CI): block staged test files that add a
# new relative-path `jest.mock('./...')` / `jest.mock('../...')` unless the
# factory follows Pattern A (spreads `jest.requireActual(<same path>)`), or
# the line carries an on-line `gc1-allow: <reason>` escape hatch. See
# AGENTS.md → "No new internal jest.mock() (GC1 ratchet)" and
# scripts/check-gc1-pattern-a.ts (the structural check that replaced the
# previous textual-only grep — BUG-1051).
STAGED_TESTS=$(git diff --cached --name-only --diff-filter=d -- '*.test.ts' '*.test.tsx')
if [ -n "$STAGED_TESTS" ]; then
  pnpm exec tsx scripts/check-gc1-pattern-a.ts || exit 1
fi

# Whole-tree `tsc --build` + surgical jest moved to pre-push (WI-450 / gate-spec
# D1). At a partial commit the working tree != the index, so whole-tree type/test
# checks are structurally wrong here (an unrelated in-progress file breaks an
# otherwise-clean partial commit). They are valid at pre-push, where the working
# tree ≈ HEAD — see .husky/pre-push -> scripts/pre-push-tests.sh. CI is the
# authoritative backstop regardless.
