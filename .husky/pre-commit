#!/usr/bin/env sh
set -e
pnpm exec lint-staged

# Eval-harness guard: prompt-touching files require an accompanying snapshot
# diff. Without this, prompt drift ships silently (the eval harness only
# catches it post-hoc on the next manual run). See CLAUDE.md "When changing
# LLM prompts, run the eval harness".
#
# Triggers on staged changes to:
#   - apps/api/src/services/**/*-prompts.ts
#   - apps/api/src/services/llm/*.ts (excluding tests)
# Requires at least one staged file under apps/api/eval-llm/snapshots/.
# Bypass with `git commit --no-verify` if the change is a pure refactor.
PROMPT_CHANGED=$(git diff --cached --name-only --diff-filter=d \
  | grep -E '(apps/api/src/services/.*-prompts\.ts$|apps/api/src/services/llm/.+\.ts$|apps/api/src/services/dictation/generate\.ts$)' \
  | grep -vE '\.test\.ts$' || true)
if [ -n "$PROMPT_CHANGED" ]; then
  SNAPSHOT_CHANGED=$(git diff --cached --name-only \
    | grep -E '^apps/api/eval-llm/snapshots/' || true)
  if [ -z "$SNAPSHOT_CHANGED" ]; then
    echo ""
    echo "pre-commit: prompt-touching files staged without a snapshot diff."
    echo ""
    echo "Files that triggered the check:"
    echo "$PROMPT_CHANGED" | sed 's/^/  /'
    echo ""
    echo "Run: pnpm eval:llm   (then re-stage the snapshot files)"
    echo ""
    echo "If this change cannot affect generation output (pure refactor,"
    echo "rename, comment, type-only), pass --no-verify."
    exit 1
  fi
fi

# i18n staleness guard: when en.json is staged, every locale must already match
# its key/variable shape. Without this the staleness check exists but never
# runs in CI/husky, so missing-key drift ships silently. Skip when only
# non-en locale files are staged (translator output committing back).
I18N_EN_CHANGED=$(git diff --cached --name-only --diff-filter=d \
  | grep -E '^apps/mobile/src/i18n/locales/en\.json$' || true)
if [ -n "$I18N_EN_CHANGED" ]; then
  echo "pre-commit: running check:i18n (en.json changed)..."
  pnpm exec tsx scripts/check-i18n-staleness.ts || exit 1
fi

# GC1 ratchet (pre-commit mirror of CI): block staged test files that add a
# new relative-path `jest.mock('./...')` / `jest.mock('../...')` without an
# on-same-line `gc1-allow: <reason>` justification. This catches the common
# mistake of putting `// gc1-allow` on the line *after* `jest.mock(` — the
# CI grep is line-by-line, so a next-line comment does NOT pass. See
# CLAUDE.md → "No new internal jest.mock() (GC1 ratchet)".
STAGED_TESTS=$(git diff --cached --name-only --diff-filter=d -- '*.test.ts' '*.test.tsx')
if [ -n "$STAGED_TESTS" ]; then
  GC1_VIOLATIONS=$(echo "$STAGED_TESTS" \
    | xargs -I{} git diff --cached --unified=0 -- {} \
    | grep -E '^\+[^+]' \
    | grep -E "jest\.mock\(['\"\`]\.\.?/" \
    | grep -iv 'gc1-allow' || true)
  if [ -n "$GC1_VIOLATIONS" ]; then
    echo ""
    echo "pre-commit: GC1 — new internal jest.mock() without same-line gc1-allow."
    echo ""
    echo "Offending added lines:"
    echo "$GC1_VIOLATIONS" | sed 's/^/  /'
    echo ""
    echo "Fix one of two ways:"
    echo "  1. Use jest.requireActual() + targeted overrides instead of mocking the module."
    echo "  2. If it really is an external boundary (LLM, push, email, Stripe, etc.),"
    echo "     put the comment on the SAME line as jest.mock(:"
    echo "       jest.mock('./foo' /* gc1-allow: <reason> */, () => ({ ... }))"
    echo "       jest.mock('./foo', () => ({ ... })); // gc1-allow: <reason>"
    echo ""
    echo "A comment on the line BELOW jest.mock( does NOT satisfy the check."
    exit 1
  fi
fi

# Full project-reference type-check (incremental via composite tsconfig).
# Emits .d.ts to dist/ (gitignored) + .tsbuildinfo (gitignored) for incremental caching.
# Skip if no .ts/.tsx files are staged — docs/config-only commits need no tsc.
STAGED_TS=$(git diff --cached --name-only --diff-filter=d -- '*.ts' '*.tsx')
if [ -n "$STAGED_TS" ]; then
  echo "pre-commit: running tsc --build (incremental)..."
  pnpm exec tsc --build || exit 1
fi

# Surgical tests — only tests related to staged files (see scripts/pre-commit-tests.sh)
bash scripts/pre-commit-tests.sh
